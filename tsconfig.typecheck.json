{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@scope-flux/core": ["packages/core/src/index.ts"],
      "@scope-flux/scheduler": ["packages/scheduler/src/index.ts"],
      "@scope-flux/serializer": ["packages/serializer/src/index.ts"],
      "@scope-flux/react": ["packages/react/src/index.tsx"],
      "@scope-flux/inspect": ["packages/inspect/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/test/**/*.ts",
    "packages/*/test/**/*.tsx",
    "vite.config.ts"
  ]
}
