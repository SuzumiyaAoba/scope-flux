{
  "name": "scope-flux",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuzumiyaAoba/scope-flux.git"
  },
  "homepage": "https://github.com/SuzumiyaAoba/scope-flux",
  "bugs": {
    "url": "https://github.com/SuzumiyaAoba/scope-flux/issues"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "docs-site"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:packages",
    "build:packages": "npm -w @suzumiyaaoba/scope-flux-core run build && npm -w @suzumiyaaoba/scope-flux-scheduler run build && npm -w @suzumiyaaoba/scope-flux-serializer run build && npm -w @suzumiyaaoba/scope-flux-inspect run build && npm -w @suzumiyaaoba/scope-flux-react run build && npm -w @suzumiyaaoba/scope-flux-benchmark run build",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome lint packages scripts e2e",
    "lint:fix": "biome lint --write packages scripts e2e",
    "format": "biome format --write .",
    "clean": "rm -rf packages/*/dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint:ids": "node scripts/check-duplicate-cell-ids.mjs",
    "bench": "npm run build && node packages/benchmark/dist/run.js",
    "bench:regression": "npm run build && node scripts/check-benchmark-regression.mjs",
    "verify:observability": "npm run build && node scripts/verify-observability-exclusion.mjs",
    "docs:api": "typedoc --options typedoc.json",
    "docs:sync": "node scripts/sync-doc-assets.mjs",
    "docs:dev": "npm --prefix docs-site run dev",
    "docs:build": "npm --prefix docs-site run build",
    "docs:preview": "npm --prefix docs-site run preview",
    "samples:build": "npm run build:packages && tsc -p samples/tsconfig.json",
    "samples:pure": "npm run samples:build && node samples/dist/pure.js",
    "samples:react": "npm run samples:build && node samples/dist/react.js",
    "samples:all": "npm run samples:build && node samples/dist/pure.js && node samples/dist/react.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^26.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rspress": "^1.47.1",
    "tsup": "^8.3.6",
    "typedoc": "^0.28.13",
    "typescript": "^5.8.2",
    "vite": "^7.0.0",
    "vitest": "^4.0.18"
  }
}
